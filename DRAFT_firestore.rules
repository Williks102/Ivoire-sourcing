rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catch-all rule at the top to securely deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Check if user has specific role (employer / candidate / admin)
    // Avoid lookup if user document does not exist yet to prevent permissions crash
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserRole() == role;
    }

    // Admin authorization rule combining hardcoded dev email and database lookup
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == "koffiw4@gmail.com" && request.auth.token.email_verified == true) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == 'admin')
      );
    }

    // ==========================================
    // SCHEMA VALIDATION BLUEPRINTS
    // ==========================================

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 150 &&
             data.email is string && data.email.size() <= 150 &&
             data.role is string && (data.role == 'candidate' || data.role == 'employer' || data.role == 'admin') &&
             data.isVerified is bool &&
             data.isPremium is bool &&
             data.averageRating is number &&
             data.reviewCount is number &&
             data.createdAt is string && data.createdAt.size() <= 64 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 32)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('cvName' in data) || (data.cvName is string && data.cvName.size() <= 200)) &&
             (!('cvUrl' in data) || (data.cvUrl is string && data.cvUrl.size() <= 1000000)) &&
             (!('skills' in data) || (data.skills is list && data.skills.size() <= 30)) &&
             (!('verificationDocs' in data) || (data.verificationDocs is list && data.verificationDocs.size() <= 5));
    }

    function isValidJob(data) {
      return data.employerId is string && data.employerId.size() > 0 && data.employerId.size() <= 128 &&
             data.title is string && data.title.size() <= 150 &&
             data.description is string && data.description.size() <= 10000 &&
             data.category is string && (data.category == 'nounou' || data.category == 'chauffeur' || data.category == 'boy' || data.category == 'cuisinier' || data.category == 'autre') &&
             data.location is string && data.location.size() <= 100 &&
             data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected' || data.status == 'closed') &&
             data.isPremium is bool &&
             data.createdAt is string && data.createdAt.size() <= 64 &&
             (!('salaryRange' in data) || (data.salaryRange is string && data.salaryRange.size() <= 100));
    }

    function isValidApplication(data) {
      return data.jobId is string && data.jobId.size() > 0 && data.jobId.size() <= 128 &&
             data.candidateId is string && data.candidateId.size() > 0 && data.candidateId.size() <= 128 &&
             data.employerId is string && data.employerId.size() > 0 && data.employerId.size() <= 128 &&
             data.status is string && (data.status == 'pending' || data.status == 'accepted' || data.status == 'rejected' || data.status == 'approved') &&
             data.message is string && data.message.size() <= 5000 &&
             data.createdAt is string && data.createdAt.size() <= 64 &&
             (!('candidateName' in data) || (data.candidateName is string && data.candidateName.size() <= 150)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('experienceYears' in data) || (data.experienceYears is number)) &&
             (!('cvName' in data) || (data.cvName is string && data.cvName.size() <= 200)) &&
             (!('cvUrl' in data) || (data.cvUrl is string && data.cvUrl.size() <= 1000000));
    }

    function isValidReview(data) {
      return data.targetUserId is string && data.targetUserId.size() > 0 && data.targetUserId.size() <= 128 &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() <= 128 &&
             data.jobId is string && data.jobId.size() > 0 && data.jobId.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidUnlock(data) {
      return data.employerId is string && data.employerId.size() > 0 && data.employerId.size() <= 128 &&
             data.candidateId is string && data.candidateId.size() > 0 && data.candidateId.size() <= 128 &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    // ==========================================
    // RESOURCE ROUTES (ABAC ACCESS CONTROL)
    // ==========================================

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Any signed-in user or public can read candidate profiles (essential for search)
      // Private contact info is protected via the unlocks collection and client access rules
      allow read: if isSignedIn();
      
      // Verified profile creation
      allow create: if isOwner(userId) && 
                       isEmailVerified() &&
                       incoming().uid == userId &&
                       isValidUser(incoming()) && 
                       incoming().role != 'admin' &&
                       incoming().isVerified == false && 
                       incoming().isPremium == false && 
                       incoming().averageRating == 0 && 
                       incoming().reviewCount == 0;
      
      // Separated tier updates to prevent self-elevation & self-verification
      allow update: if (
        isAdmin() && isValidUser(incoming())
      ) || (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().uid == userId &&
        incoming().email == existing().email &&
        incoming().createdAt == existing().createdAt &&
        // Prevent candidates from marking themselves as premium or verified or overriding rating metrics
        !incoming().diff(existing()).affectedKeys().hasAny(['isVerified', 'isPremium', 'averageRating', 'reviewCount', 'uid', 'email']) &&
        // Self-change cannot grant admin status
        incoming().role != 'admin'
      );

      allow delete: if isAdmin();
    }

    // --- JOBS COLLECTION ---
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                       isEmailVerified() && 
                       isOwner(incoming().employerId) && 
                       hasRole('employer') && 
                       isValidJob(incoming()) && 
                       incoming().status == 'pending' && 
                       incoming().isPremium == false;

      allow update: if (
        isAdmin() && isValidJob(incoming())
      ) || (
        isOwner(existing().employerId) && 
        isValidJob(incoming()) &&
        incoming().employerId == existing().employerId &&
        incoming().createdAt == existing().createdAt &&
        // Prevent owners from auto-approving their own job or adding Premium tag on their own
        !incoming().diff(existing()).affectedKeys().hasAny(['status', 'isPremium'])
      );

      allow delete: if isAdmin() || isOwner(existing().employerId);
    }

    // --- APPLICATIONS COLLECTION ---
    match /applications/{appId} {
      // Secure listing queries to ensure candidates only see their apps, employers see apps for their jobs, and admins see all
      allow read: if isSignedIn() && (isOwner(resource.data.candidateId) || isOwner(resource.data.employerId) || isAdmin());
      
      allow create: if isSignedIn() && 
                       isEmailVerified() && 
                       isOwner(incoming().candidateId) && 
                       hasRole('candidate') && 
                       exists(/databases/$(database)/documents/jobs/$(incoming().jobId)) && 
                       isValidApplication(incoming()) && 
                       incoming().status == 'pending';

      allow update: if (
        isAdmin() && isValidApplication(incoming())
      ) || (
        // Action: Employer accepting or rejecting an application status
        isOwner(existing().employerId) && 
        isValidApplication(incoming()) &&
        incoming().candidateId == existing().candidateId &&
        incoming().jobId == existing().jobId &&
        incoming().createdAt == existing().createdAt &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      ) || (
        // Action: Candidate editing message or uploading CV without mutating status
        isOwner(existing().candidateId) && 
        isValidApplication(incoming()) &&
        incoming().employerId == existing().employerId &&
        incoming().jobId == existing().jobId &&
        incoming().createdAt == existing().createdAt &&
        !incoming().diff(existing()).affectedKeys().hasAny(['status'])
      );

      allow delete: if isAdmin() || isOwner(existing().candidateId);
    }

    // --- REVIEWS COLLECTION ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                       isEmailVerified() && 
                       isOwner(incoming().authorId) && 
                       exists(/databases/$(database)/documents/users/$(incoming().targetUserId)) && 
                       isValidReview(incoming());

      allow update, delete: if isAdmin();
    }

    // --- CANDIDATE UNLOCK RECORDS (ZERO DIRECT PII BREACH) ---
    match /unlocks/{unlockId} {
      // Private direct contacts. Only unlocked candidate or unlocked employer gets visibility.
      allow read: if isSignedIn() && (isOwner(resource.data.employerId) || isOwner(resource.data.candidateId) || isAdmin());
      
      allow create: if isSignedIn() && 
                       isEmailVerified() && 
                       isOwner(incoming().employerId) && 
                       exists(/databases/$(database)/documents/users/$(incoming().candidateId)) && 
                       isValidUnlock(incoming());

      allow update, delete: if isAdmin();
    }
  }
}
